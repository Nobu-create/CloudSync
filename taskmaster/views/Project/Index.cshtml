@model IEnumerable<CloudSync.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary"><i class="bi bi-kanban"></i> My Projects</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Project
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-kanban display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">No projects yet</h4>
        <p class="text-muted">Create your first project to get started.</p>
        <a asp-action="Create" class="btn btn-primary btn-lg mt-2">Create Project</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var project in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold mb-0">@project.Name</h5>
                            <span class="badge bg-@(project.StatusId == "active" ? "success" : project.StatusId == "completed" ? "primary" : "secondary")">
                                @project.StatusId
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <p class="card-text text-muted small">@project.Description</p>
                        }

                        @if (project.DueDate.HasValue)
                        {
                            <p class="small text-muted mb-2">
                                <i class="bi bi-calendar"></i> Due: @project.DueDate.Value.ToString("MMM dd, yyyy")
                            </p>
                        }

                        <!-- Progress bar -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Progress</span>
                                <span>@project.CompletedTasks / @project.TotalTasks tasks</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-primary" role="progressbar"
                                     style="width: @project.ProgressPercent%"
                                     aria-valuenow="@project.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                        </div>

                        <!-- Members -->
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-people text-muted me-1"></i>
                            <span class="small text-muted">@project.Members.Count member(s)</span>
                            @if (project.OverdueTasks > 0)
                            {
                                <span class="badge bg-danger ms-auto">@project.OverdueTasks overdue</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-eye"></i> View
                        </a>
                        <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this project?')">
                            <input type="hidden" name="id" value="@project.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
