@model IEnumerable<CloudSync.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-kanban" style="color:var(--accent-blue)"></i> My Projects</h2>
        <div class="sub">@Model.Count() project(s) &middot; @Model.Count(p => p.StatusId == "active") active</div>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> New Project</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-kanban"></i></div>
        <h5>No projects yet</h5>
        <p>Create your first project to start collaborating.</p>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create Project</a>
    </div>
}
else
{
    <div class="row g-4 stagger">
        @foreach (var project in Model)
        {
            <div class="col-md-6 col-lg-4 fade-in-up">
                <div class="project-card">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h5 class="mb-0 fw-bold" style="font-size:15px;color:var(--text-primary)">@project.Name</h5>
                        <span class="project-status @project.StatusId">@project.StatusId</span>
                    </div>

                    @if (!string.IsNullOrEmpty(project.Description))
                    {
                        <p style="font-size:12px;color:var(--text-muted);margin:6px 0 10px">@project.Description</p>
                    }

                    <div class="d-flex gap-3 flex-wrap mb-3" style="font-size:11px;color:var(--text-muted)">
                        <span><i class="bi bi-list-task"></i> @project.TotalTasks tasks</span>
                        <span><i class="bi bi-check-circle"></i> @project.CompletedTasks done</span>
                        @if (project.DueDate.HasValue)
                        {
                            <span><i class="bi bi-calendar3"></i> @project.DueDate.Value.ToString("MMM dd, yyyy")</span>
                        }
                        @if (project.OverdueTasks > 0)
                        {
                            <span style="color:var(--accent-danger)">
                                <i class="bi bi-exclamation-triangle"></i> @project.OverdueTasks overdue
                            </span>
                        }
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1" style="font-size:11px;color:var(--text-muted)">
                            <span>Progress</span>
                            <span style="color:var(--accent-blue);font-weight:700">@project.ProgressPercent%</span>
                        </div>
                        <div class="progress" style="height:6px">
                            <div class="progress-bar @(project.ProgressPercent == 100 ? "bg-success" : "")"
                                 style="width:@project.ProgressPercent%"></div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <div style="font-size:10px;color:var(--text-muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px">Members</div>
                            <div class="avatar-stack">
                                @{
                                    var colors = new[] { "", "green", "orange", "purple" };
                                    int ci = 0;
                                }
                                @foreach (var member in project.Members.Take(4))
                                {
                                    <div class="avatar @colors[ci % colors.Length]" title="@member.User?.FullName">
                                        @(member.User?.FullName?.Substring(0, 1).ToUpper() ?? "?")
                                    </div>
                                    ci++;
                                }
                                @if (project.Members.Count > 4)
                                {
                                    <div class="avatar" style="background:var(--bg-hover);color:var(--text-muted);font-size:10px">
                                        +@(project.Members.Count - 4)
                                    </div>
                                }
                            </div>
                        </div>
                        <span style="font-size:11px;color:var(--text-muted)">@project.Members.Count member(s)</span>
                    </div>

                    <div class="d-flex gap-2 mt-auto pt-2" style="border-top:1px solid var(--border-color)">
                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="bi bi-eye"></i> View
                        </a>
                        <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-ghost btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this project?')">
                            <input type="hidden" name="id" value="@project.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--accent-danger)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}