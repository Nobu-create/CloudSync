@model IEnumerable<CloudSync.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Notifications</h4>
        <div style="font-size:12px;color:var(--text-muted)">@Model.Count(n => !n.IsRead) unread</div>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline btn-sm">Mark all as read</button>
        </form>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-bell-slash" style="font-size:48px;color:var(--text-muted)"></i>
        <h5 class="mt-3" style="color:var(--text-muted)">No notifications</h5>
        <p style="color:var(--text-muted);font-size:13px">You're all caught up!</p>
    </div>
}
else
{
    <div class="card">
        <ul class="list-group list-group-flush">
            @foreach (var n in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center @(!n.IsRead ? "bg-unread" : "")"
                    style="background:@(!n.IsRead ? "rgba(79,142,247,0.05)" : "transparent");border-color:var(--border)">
                    <div class="d-flex align-items-start gap-3">
                        <div style="margin-top:2px">
                            <i class="bi bi-bell@(!n.IsRead ? "-fill" : "")" style="color:@(!n.IsRead ? "var(--blue)" : "var(--text-muted)")"></i>
                        </div>
                        <div>
                            <div style="font-size:13px;color:@(!n.IsRead ? "var(--text)" : "var(--text-muted)")">@n.Message</div>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px">@n.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        @if (!n.IsRead)
                        {
                            <form asp-action="MarkRead" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-outline" style="font-size:11px">Mark read</button>
                            </form>
                        }
                        <form asp-action="Delete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm" style="background:none;border:none;color:var(--red);font-size:13px">
                                <i class="bi bi-x"></i>
                            </button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    </div>
}
