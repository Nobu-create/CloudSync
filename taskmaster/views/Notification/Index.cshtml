@model IEnumerable<CloudSync.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-bell" style="color:var(--accent-blue)"></i> Notifications</h2>
        <div class="sub">
            @if (unreadCount > 0)
            {
                <span style="color:var(--accent-blue);font-weight:600">@unreadCount unread</span>
                <span> &middot; @Model.Count() total</span>
            }
            else
            {

                <span>All caught up!</span>
            }
        </div>
    </div>
    @if (unreadCount > 0)
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-check2-all"></i> Mark all read
            </button>
        </form>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-bell-slash"></i></div>
        <h5>No notifications</h5>
        <p>You're all caught up — nothing to see here.</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            @foreach (var n in Model)
            {
                <div class="notif-item @(!n.IsRead ? "unread" : "")">
                    <div class="notif-icon @(!n.IsRead ? "info" : "")">
                        <i class="bi @(!n.IsRead ? "bi-bell-fill" : "bi-bell")"
                           style="@(n.IsRead ? "color:var(--text-muted)" : "")"></i>
                    </div>
                    <div style="flex:1;min-width:0">
                        <div class="notif-msg" style="@(!n.IsRead ? "font-weight:500" : "color:var(--text-muted)")">
                            @n.Message
                        </div>
                        <div class="notif-time">
                            <i class="bi bi-clock"></i> @n.CreatedAt.ToString("MMM dd, yyyy · HH:mm")
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-1 flex-shrink-0">
                        @if (!n.IsRead)
                        {
                            <div class="notif-dot me-1"></div>
                            <form asp-action="MarkRead" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="font-size:11px;white-space:nowrap">
                                    <i class="bi bi-check2"></i> Mark read
                                </button>
                            </form>
                        }
                        <form asp-action="Delete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--accent-danger)" title="Dismiss">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
}