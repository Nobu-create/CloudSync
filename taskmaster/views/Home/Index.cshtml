@using CloudSync.Models
@model TaskViewModel
@{
    ViewData["Title"] = "My Tasks";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-check2-square" style="color:var(--accent-blue)"></i> My Tasks</h2>
        <div class="sub">
            @Model.Tasks.Count(t => t.StatusId == "open") open &middot;
            @Model.Tasks.Count(t => t.Overdue) overdue &middot;
            @Model.Tasks.Count(t => t.StatusId == "closed") completed
        </div>
    </div>
    <a asp-action="Add" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add Task</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show">@TempData["Info"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row g-4">
    <!-- Filters Sidebar -->
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-funnel" style="color:var(--accent-blue)"></i> Filters
            </div>
            <div class="card-body">
                <form asp-action="Filter" method="post">
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select name="categoryFilter" class="form-select" asp-items="Model.Categories">
                            <option value="all">All Categories</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Due Date</label>
                        <select name="dueFilter" class="form-select" asp-items="Model.DueFilters">
                            <option value="all">All Dates</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="statusFilter" class="form-select" asp-items="Model.Statuses">
                            <option value="all">All Statuses</option>
                        </select>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-search"></i> Apply Filters
                        </button>
                        <a asp-action="Index" class="btn btn-ghost btn-sm">
                            <i class="bi bi-x"></i> Clear Filters
                        </a>
                    </div>
                </form>
                @if (Model.Tasks.Any(t => t.StatusId == "closed"))
                {
                    <hr style="border-color:var(--border-color)">
                    <form asp-action="DeleteCompleted" method="post" onsubmit="return confirm('Delete all completed tasks?')">
                        <input type="hidden" name="returnUrl" value="@Model.CurrentFilters.FilterString" />
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="bi bi-trash"></i> Delete Completed
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- Mini stats -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-bar-chart" style="color:var(--accent-blue)"></i> Stats
            </div>
            <div class="card-body">
                <div class="row text-center g-2">
                    <div class="col-6">
                        <div style="font-size:24px;font-weight:800;color:var(--accent-blue)">
                            @Model.Tasks.Count(t => t.StatusId == "open")
                        </div>
                        <div style="font-size:11px;color:var(--text-muted)">Open</div>
                    </div>
                    <div class="col-6">
                        <div style="font-size:24px;font-weight:800;color:var(--accent-success)">
                            @Model.Tasks.Count(t => t.StatusId == "closed")
                        </div>
                        <div style="font-size:11px;color:var(--text-muted)">Done</div>
                    </div>
                    <div class="col-12 mt-1">
                        <div style="font-size:24px;font-weight:800;color:var(--accent-danger)">
                            @Model.Tasks.Count(t => t.Overdue)
                        </div>
                        <div style="font-size:11px;color:var(--text-muted)">Overdue</div>
                    </div>
                </div>
                @if (Model.Tasks.Any())
                {
                    var totalTasks = Model.Tasks.Count();
                    var completedCount = Model.Tasks.Count(t => t.StatusId == "closed");
                    var pct = totalTasks > 0 ? (int)((double)completedCount / totalTasks * 100) : 0;
                    <div class="mt-3">
                        <div class="d-flex justify-content-between" style="font-size:11px;color:var(--text-muted);margin-bottom:4px">
                            <span>Completion</span>
                            <span style="color:var(--accent-blue);font-weight:600">@pct%</span>
                        </div>
                        <div class="progress" style="height:6px">
                            <div class="progress-bar @(pct == 100 ? "bg-success" : "")" style="width:@pct%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Task Grid -->
    <div class="col-md-9">
        @if (Model.Tasks.Any())
        {
            <!-- Live search -->
            <div class="search-input-wrap mb-3">
                <i class="bi bi-search"></i>
                <input type="text" id="task-search" class="form-control" placeholder="Search tasks…">
            </div>

            <!-- Quick filter chips -->
            <div class="filter-chips">
                <span class="filter-chip active" data-filter="all">All</span>
                <span class="filter-chip" data-filter="open">Open</span>
                <span class="filter-chip" data-filter="closed">Completed</span>
                <span class="filter-chip" data-filter="overdue">Overdue</span>
                <span class="filter-chip" data-filter="high">High Priority</span>
            </div>

            <div class="row g-3" id="task-grid">
                @foreach (var task in Model.Tasks)
                {
                    <div class="col-lg-6 col-xl-4 task-item"
                         data-status="@task.StatusId"
                         data-overdue="@task.Overdue.ToString().ToLower()"
                         data-priority="@(task.Priority?.Name?.ToLower() ?? "")">
                        <div class="card h-100 @(task.Overdue ? "border-danger" : "") @(task.StatusId == "closed" ? "done-card" : "")">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="card-title mb-0 task-title"
                                        style="@(task.StatusId == "closed" ? "text-decoration:line-through;color:var(--text-muted)" : "color:var(--text-primary)")">
                                        @task.Description
                                    </h6>
                                    <div class="dropdown ms-2">
                                        <button class="btn btn-ghost btn-sm py-0 px-1" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" asp-action="Edit" asp-route-id="@task.Id">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                            </li>
                                            <li>
                                                <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this task?')">
                                                    <input type="hidden" name="id" value="@task.Id" />
                                                    <input type="hidden" name="returnUrl" value="@Model.CurrentFilters.FilterString" />
                                                    <button type="submit" class="dropdown-item" style="color:var(--accent-danger)">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </div>

                                @if (task.Category != null)
                                {
                                    <div style="font-size:12px;color:var(--text-muted);margin-bottom:6px">
                                        <i class="bi bi-folder2"></i> @task.Category.Name
                                    </div>
                                }

                                @if (task.DueDate.HasValue)
                                {
                                    <div style="font-size:12px;margin-bottom:8px;color:@(task.Overdue ? "var(--accent-danger)" : "var(--text-muted)")">
                                        <i class="bi bi-calendar3"></i> @task.DueDate.Value.ToString("MMM dd, yyyy")
                                        @if (task.Overdue)
                                        {
                                            <span class="chip chip-overdue ms-1" style="font-size:10px;padding:1px 7px">Overdue</span>
                                        }
                                    </div>
                                }

                                <div class="d-flex gap-1 flex-wrap">
                                    @if (task.Priority != null)
                                    {
                                        <span class="chip chip-@task.Priority.Name.ToLower()">
                                            @if (task.Priority.Name == "High") { <i class="bi bi-fire"></i> }
                                            else if (task.Priority.Name == "Medium") { <i class="bi bi-dash-circle"></i> }
                                            else { <i class="bi bi-arrow-down-circle"></i> }
                                            @task.Priority.Name
                                        </span>
                                    }
                                    <span class="chip @(task.StatusId == "open" ? "chip-open" : "chip-closed")">
                                        @task.Status?.Name
                                    </span>
                                </div>

                                @if (task.Project != null)
                                {
                                    <div style="font-size:11px;color:var(--text-muted);margin-top:6px">
                                        <i class="bi bi-kanban"></i> @task.Project.Name
                                    </div>
                                }
                                @if (task.AssignedTo != null)
                                {
                                    <div style="font-size:11px;color:var(--text-muted)">
                                        <i class="bi bi-person"></i> @task.AssignedTo.FullName
                                    </div>
                                }
                            </div>
                            @if (task.StatusId == "open")
                            {
                                <div class="card-footer">
                                    <form asp-action="MarkComplete" method="post">
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <input type="hidden" name="returnUrl" value="@Model.CurrentFilters.FilterString" />
                                        <button type="submit" class="btn btn-success btn-sm w-100">
                                            <i class="bi bi-check-circle"></i> Mark Complete
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div id="no-results" style="display:none" class="empty-state mt-4">
                <div class="empty-state-icon"><i class="bi bi-search"></i></div>
                <h5>No tasks match</h5>
                <p>Try a different search or filter.</p>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-check2-square"></i></div>
                <h5>No tasks found</h5>
                <p>
                    @if (Model.CurrentFilters.FilterString != "all-all-all")
                    {
                        <span>Try adjusting your filters or </span>
                    }
                    <a asp-action="Add">add your first task</a>
                </p>
                <a asp-action="Add" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add Task</a>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const cat = document.querySelector('select[name="categoryFilter"]');
        const due = document.querySelector('select[name="dueFilter"]');
        const sts = document.querySelector('select[name="statusFilter"]');
        if (cat) cat.value = '@Model.CurrentFilters.CategoryId';
        if (due) due.value = '@Model.CurrentFilters.Due';
        if (sts) sts.value = '@Model.CurrentFilters.StatusId';

        const items     = document.querySelectorAll('.task-item');
        const noResults = document.getElementById('no-results');
        const searchBox = document.getElementById('task-search');
        let activeFilter = 'all';

        function applyFilters() {
            const q = searchBox ? searchBox.value.toLowerCase() : '';
            let visible = 0;
            items.forEach(function (item) {
                const title    = item.querySelector('.task-title')?.textContent.toLowerCase() || '';
                const status   = item.dataset.status;
                const overdue  = item.dataset.overdue === 'true';
                const priority = item.dataset.priority;
                const matchSearch = !q || title.includes(q);
                let matchChip = true;
                if (activeFilter === 'open')    matchChip = status === 'open';
                if (activeFilter === 'closed')  matchChip = status === 'closed';
                if (activeFilter === 'overdue') matchChip = overdue;
                if (activeFilter === 'high')    matchChip = priority === 'high';
                const show = matchSearch && matchChip;
                item.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
        }

        if (searchBox) searchBox.addEventListener('input', applyFilters);

        document.querySelectorAll('.filter-chip').forEach(function (chip) {
            chip.addEventListener('click', function () {
                document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                activeFilter = this.dataset.filter;
                applyFilters();
            });
        });
    });
</script>