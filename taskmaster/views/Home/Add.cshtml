@model CloudSync.Models.ToDo
@{
    ViewData["Title"] = "Add New Task";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">Add New Task</h4>
            <a asp-action="Index" class="btn btn-outline btn-sm">← Back</a>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description <span style="color:var(--red)">*</span></label>
                        <input asp-for="Description" class="form-control" placeholder="What needs to be done?" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="PriorityId" class="form-label">Priority</label>
                            <select asp-for="PriorityId" class="form-select" asp-items="ViewBag.Priorities">
                                <option value="">Select Priority</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label">Category <span style="color:var(--red)">*</span></label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                <option value="">Select Category</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StatusId" class="form-label">Status <span style="color:var(--red)">*</span></label>
                            <select asp-for="StatusId" class="form-select" asp-items="ViewBag.Statuses">
                                <option value="">Select Status</option>
                            </select>
                            <span asp-validation-for="StatusId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label">Due Date <span style="color:var(--red)">*</span></label>
                            <input asp-for="DueDate" type="date" class="form-control" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProjectId" class="form-label">Project</label>
                            <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.Projects">
                                <option value="">No Project</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="AssignedToUserId" class="form-label">Assign To</label>
                        <select asp-for="AssignedToUserId" class="form-select" asp-items="ViewBag.TeamMembers">
                            <option value="">Assign to myself</option>
                        </select>
                        <div class="form-text" style="color:var(--muted);font-size:11px">Only team members from your projects appear here</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save Task
                        </button>
                        <a asp-action="Index" class="btn btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
