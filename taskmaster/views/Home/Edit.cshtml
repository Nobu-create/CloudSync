@model CloudSync.Models.ToDo
@{
    ViewData["Title"] = "Edit Task";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">Edit Task</h4>
            <a asp-action="Index" class="btn btn-outline btn-sm">← Back</a>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description <span style="color:var(--red)">*</span></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="PriorityId" class="form-label">Priority</label>
                            <select asp-for="PriorityId" class="form-select" asp-items="ViewBag.Priorities">
                                <option value="">Select Priority</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label">Category</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                <option value="">Select Category</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StatusId" class="form-label">Status</label>
                            <select asp-for="StatusId" class="form-select" asp-items="ViewBag.Statuses">
                                <option value="">Select Status</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label">Due Date</label>
                            <input asp-for="DueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProjectId" class="form-label">Project</label>
                            <select asp-for="ProjectId" class="form-select" asp-items="ViewBag.Projects">
                                <option value="">No Project</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="AssignedToUserId" class="form-label">Assign To</label>
                        <select asp-for="AssignedToUserId" class="form-select" asp-items="ViewBag.TeamMembers">
                            <option value="">Assign to myself</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
