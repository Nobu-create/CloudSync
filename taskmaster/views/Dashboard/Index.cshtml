@model CloudSync.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="fw-bold mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h2>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h2 class="fw-bold text-primary mb-0">@Model.TotalTasks</h2>
            <small class="text-muted">Total Tasks</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h2 class="fw-bold text-success mb-0">@Model.CompletedTasks</h2>
            <small class="text-muted">Completed</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h2 class="fw-bold text-danger mb-0">@Model.OverdueTasks</h2>
            <small class="text-muted">Overdue</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h2 class="fw-bold text-warning mb-0">@Model.HighPriorityTasks</h2>
            <small class="text-muted">High Priority</small>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold">Tasks by Priority</div>
            <div class="card-body d-flex justify-content-center">
                <canvas id="priorityChart" style="max-height: 220px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white fw-bold">Task Completion</div>
            <div class="card-body d-flex justify-content-center">
                <canvas id="statusChart" style="max-height: 220px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Projects + Recent Tasks -->
<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-bold">Active Projects</span>
                <a asp-controller="Project" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Projects.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <p>No projects yet. <a asp-controller="Project" asp-action="Create">Create one!</a></p>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var project in Model.Projects.Take(5))
                        {
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" class="fw-semibold text-decoration-none">
                                        @project.Name
                                    </a>
                                    <span class="small text-muted">@project.ProgressPercent%</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-primary" style="width: @project.ProgressPercent%"></div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <span class="fw-bold">Recent Tasks</span>
                <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentTasks.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <p>No tasks yet. <a asp-controller="Home" asp-action="Add">Add one!</a></p>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var task in Model.RecentTasks)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span class="small @(task.StatusId == "closed" ? "text-decoration-line-through text-muted" : "")">
                                    @task.Description
                                </span>
                                <span class="badge bg-@(task.Priority?.BadgeColor ?? "secondary")">
                                    @(task.Priority?.Name ?? "Medium")
                                </span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Priority chart
    new Chart(document.getElementById('priorityChart'), {
        type: 'doughnut',
        data: {
            labels: ['High', 'Medium', 'Low'],
            datasets: [{
                data: [@Model.TasksByPriority["High"], @Model.TasksByPriority["Medium"], @Model.TasksByPriority["Low"]],
                backgroundColor: ['#dc3545', '#ffc107', '#198754'],
                borderWidth: 2
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });

    // Status chart
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Open', 'Completed'],
            datasets: [{
                data: [@Model.TasksByStatus["Open"], @Model.TasksByStatus["Closed"]],
                backgroundColor: ['#0d6efd', '#198754'],
                borderWidth: 2
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
</script>
}
