@model CloudSync.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-speedometer2" style="color:var(--accent-blue)"></i> Dashboard</h2>
        <div class="sub">Welcome back — here's what's happening today</div>
    </div>
    <a asp-controller="Home" asp-action="Add" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Task
    </a>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4 stagger">
    <div class="col-6 col-md-3 fade-in-up">
        <div class="stat-card stat-blue">
            <div class="stat-icon blue"><i class="bi bi-list-task"></i></div>
            <div class="stat-number">@Model.TotalTasks</div>
            <div class="stat-label">Total Tasks</div>
            <div class="stat-delta delta-neutral"><i class="bi bi-dot"></i> all tasks</div>
        </div>
    </div>
    <div class="col-6 col-md-3 fade-in-up">
        <div class="stat-card stat-green">
            <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
            <div class="stat-number">@Model.CompletedTasks</div>
            <div class="stat-label">Completed</div>
            <div class="stat-delta delta-up"><i class="bi bi-arrow-up-short"></i> great progress</div>
        </div>
    </div>
    <div class="col-6 col-md-3 fade-in-up">
        <div class="stat-card stat-red">
            <div class="stat-icon red"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="stat-number">@Model.OverdueTasks</div>
            <div class="stat-label">Overdue</div>
            @if (Model.OverdueTasks > 0)
            {
                <div class="stat-delta delta-down"><i class="bi bi-exclamation-circle"></i> needs attention</div>
            }
            else
            {
                <div class="stat-delta delta-up"><i class="bi bi-check"></i> all on track</div>
            }
        </div>
    </div>
    <div class="col-6 col-md-3 fade-in-up">
        <div class="stat-card stat-orange">
            <div class="stat-icon orange"><i class="bi bi-fire"></i></div>
            <div class="stat-number">@Model.HighPriorityTasks</div>
            <div class="stat-label">High Priority</div>
            <div class="stat-delta delta-neutral"><i class="bi bi-dot"></i> open tasks</div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-pie-chart" style="color:var(--accent-blue)"></i> Tasks by Priority
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <canvas id="priorityChart" style="max-height:220px"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <i class="bi bi-bar-chart" style="color:var(--accent-blue)"></i> Task Completion
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <canvas id="statusChart" style="max-height:220px"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Projects + Recent Tasks -->
<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-kanban" style="color:var(--accent-blue)"></i> Active Projects</span>
                <a asp-controller="Project" asp-action="Index" class="btn btn-ghost btn-sm">
                    View All <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Projects.Any())
                {
                    <div class="empty-state" style="padding:30px 20px">
                        <div class="empty-state-icon" style="width:48px;height:48px;font-size:20px;margin-bottom:12px">
                            <i class="bi bi-kanban"></i>
                        </div>
                        <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px">No projects yet</p>
                        <a asp-controller="Project" asp-action="Create" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-circle"></i> Create one
                        </a>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var project in Model.Projects.Take(5))
                        {
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id"
                                       class="fw-semibold text-decoration-none"
                                       style="font-size:13px;color:var(--text-primary)">
                                        @project.Name
                                    </a>
                                    <span style="font-size:12px;color:var(--accent-blue);font-weight:700">
                                        @project.ProgressPercent%
                                    </span>
                                </div>
                                <div class="progress" style="height:5px">
                                    <div class="progress-bar @(project.ProgressPercent == 100 ? "bg-success" : "")"
                                         style="width:@project.ProgressPercent%"></div>
                                </div>
                                <div style="font-size:11px;color:var(--text-muted);margin-top:4px">
                                    <i class="bi bi-check2"></i> @project.CompletedTasks / @project.TotalTasks tasks
                                    @if (project.OverdueTasks > 0)
                                    {
                                        <span class="chip chip-overdue ms-2" style="font-size:10px;padding:1px 7px">
                                            <i class="bi bi-exclamation-circle"></i> @project.OverdueTasks overdue
                                        </span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history" style="color:var(--accent-blue)"></i> Recent Tasks</span>
                <a asp-controller="Home" asp-action="Index" class="btn btn-ghost btn-sm">
                    View All <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentTasks.Any())
                {
                    <div class="empty-state" style="padding:30px 20px">
                        <div class="empty-state-icon" style="width:48px;height:48px;font-size:20px;margin-bottom:12px">
                            <i class="bi bi-check2-square"></i>
                        </div>
                        <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px">No tasks yet</p>
                        <a asp-controller="Home" asp-action="Add" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-circle"></i> Add one
                        </a>
                    </div>
                }
                else
                {
                    <div class="p-2">
                        @foreach (var task in Model.RecentTasks)
                        {
                            <div class="task-card @(task.Overdue ? "overdue-card" : "") @(task.StatusId == "closed" ? "done-card" : "")">
                                <div style="flex:1;min-width:0">
                                    <div style="font-size:13px;font-weight:500;@(task.StatusId == "closed" ? "text-decoration:line-through;color:var(--text-muted)" : "color:var(--text-primary)")">
                                        @task.Description
                                    </div>
                                    <div class="d-flex gap-1 flex-wrap mt-1">
                                        @if (task.Priority != null)
                                        {
                                            <span class="chip chip-@task.Priority.Name.ToLower()">@task.Priority.Name</span>
                                        }
                                        <span class="chip @(task.StatusId == "open" ? "chip-open" : "chip-closed")">
                                            @task.Status?.Name
                                        </span>
                                        @if (task.Overdue)
                                        {
                                            <span class="chip chip-overdue"><i class="bi bi-exclamation-circle"></i> Overdue</span>
                                        }
                                        @if (task.DueDate.HasValue)
                                        {
                                            <span class="chip chip-date">
                                                <i class="bi bi-calendar3"></i> @task.DueDate.Value.ToString("MMM dd")
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const legendLabels = { color: '#9095b0', font: { size: 12 }, padding: 16 };
        const baseOpts = { responsive: true, cutout: '65%', plugins: { legend: { position: 'bottom', labels: legendLabels } } };

        new Chart(document.getElementById('priorityChart'), {
            type: 'doughnut',
            data: {
                labels: ['High', 'Medium', 'Low'],
                datasets: [{ data: [@Model.TasksByPriority["High"], @Model.TasksByPriority["Medium"], @Model.TasksByPriority["Low"]],
                    backgroundColor: ['rgba(231,76,60,.85)','rgba(243,156,18,.85)','rgba(46,204,113,.85)'],
                    borderColor: 'rgba(0,0,0,0)', borderWidth: 3, hoverOffset: 6 }]
            }, options: baseOpts
        });

        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Open', 'Completed'],
                datasets: [{ data: [@Model.TasksByStatus["Open"], @Model.TasksByStatus["Closed"]],
                    backgroundColor: ['rgba(79,142,247,.85)','rgba(46,204,113,.85)'],
                    borderColor: 'rgba(0,0,0,0)', borderWidth: 3, hoverOffset: 6 }]
            }, options: baseOpts
        });
    </script>
}