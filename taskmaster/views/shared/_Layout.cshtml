<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudSync</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid px-3">
                <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-cloud-fill" style="color:#4f8ef7"></i> CloudSync
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active-nav" : "")"
                                   asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Project" ? "active-nav" : "")"
                                   asp-controller="Project" asp-action="Index">
                                    <i class="bi bi-kanban"></i> Projects
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active-nav" : "")"
                                   asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-check2-square"></i> My Tasks
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Add">
                                    <i class="bi bi-plus-circle"></i> Add Task
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-1">
                                <a class="nav-link position-relative" asp-controller="Notification" asp-action="Index">
                                    <i class="bi bi-bell"></i>
                                    <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill"
                                          style="background:var(--red);font-size:9px;display:none">0</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                                    <div style="width:28px;height:28px;border-radius:50%;background:#1a2a4a;color:#4f8ef7;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">
                                        @(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "U")
                                    </div>
                                    <span style="font-size:12px">@User.Identity?.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item" style="color:var(--red)">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Login</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus"></i> Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 py-3">
        <main role="main">@RenderBody()</main>
    </div>

    <footer style="border-top:1px solid var(--border);margin-top:3rem;padding:1rem 0;text-align:center;font-size:12px;color:var(--text-muted)">
        &copy; 2026 CloudSync Task &amp; Productivity Manager
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            // Poll for unread notifications every 30 seconds
            function checkNotifications() {
                fetch('/Notification/UnreadCount')
                    .then(r => r.json())
                    .then(data => {
                        const badge = document.getElementById('notif-badge');
                        if (data.count > 0) {
                            badge.textContent = data.count;
                            badge.style.display = 'block';
                        } else {
                            badge.style.display = 'none';
                        }
                    }).catch(() => {});
            }
            checkNotifications();
            setInterval(checkNotifications, 30000);
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
