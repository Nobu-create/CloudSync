<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudSync</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        :root {
            --bg: #0f1117;
            --card: #1e2130;
            --border: #2e3148;
            --text: #e8eaf6;
            --sec: #9095b0;
            --muted: #6b7090;
            --blue: #4f8ef7;
            --green: #2ecc71;
            --red: #e74c3c;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            color: var(--text);
        }

        .auth-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        .brand-logo {
            text-align: center;
            margin-bottom: 28px;
        }

        .brand-logo .brand-icon {
            width: 56px;
            height: 56px;
            background: rgba(79,142,247,0.15);
            border: 1px solid rgba(79,142,247,0.3);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 24px;
            color: var(--blue);
        }

        .brand-logo h2 {
            color: var(--text);
            font-weight: 600;
            font-size: 22px;
            letter-spacing: 0.5px;
        }

        .brand-logo p {
            color: var(--muted);
            font-size: 13px;
            margin-top: 4px;
        }

        .card {
            background: var(--card) !important;
            border: 1px solid var(--border) !important;
            border-radius: 14px !important;
            overflow: hidden;
        }

        .card-header {
            background: transparent !important;
            border-bottom: 1px solid var(--border) !important;
            padding: 18px 24px !important;
        }

        .card-body { padding: 24px !important; }
        .card-footer {
            background: transparent !important;
            border-top: 1px solid var(--border) !important;
            padding: 14px 24px !important;
            text-align: center;
            font-size: 13px;
            color: var(--muted);
        }

        .card-footer a {
            color: var(--blue);
            text-decoration: none;
        }

        .card-footer a:hover { text-decoration: underline; }

        .card-title {
            color: var(--text) !important;
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 2px;
        }

        .card-subtitle {
            color: var(--muted) !important;
            font-size: 12px;
        }

        .form-label {
            color: var(--sec);
            font-size: 12px;
            margin-bottom: 5px;
        }

        .form-control {
            background: #131625 !important;
            border: 1px solid var(--border) !important;
            color: var(--text) !important;
            border-radius: 8px !important;
            padding: 10px 14px !important;
            font-size: 13px;
        }

        .form-control:focus {
            border-color: var(--blue) !important;
            box-shadow: 0 0 0 3px rgba(79,142,247,0.15) !important;
        }

        .form-control::placeholder { color: var(--muted) !important; }

        .btn-primary {
            background: var(--blue) !important;
            border-color: var(--blue) !important;
            border-radius: 8px !important;
            padding: 10px !important;
            font-size: 13px;
            font-weight: 500;
            width: 100%;
            transition: all 0.15s;
        }

        .btn-primary:hover {
            background: #3a7df6 !important;
            border-color: #3a7df6 !important;
            transform: translateY(-1px);
        }

        .form-check-input {
            background-color: var(--card) !important;
            border-color: var(--border) !important;
        }

        .form-check-input:checked { background-color: var(--blue) !important; border-color: var(--blue) !important; }
        .form-check-label { color: var(--sec); font-size: 12px; }

        .alert-danger {
            background: rgba(231,76,60,0.12) !important;
            border-color: rgba(231,76,60,0.3) !important;
            color: #e74c3c !important;
            border-radius: 8px;
            font-size: 12px;
        }

        .alert-success {
            background: rgba(46,204,113,0.12) !important;
            border-color: rgba(46,204,113,0.3) !important;
            color: #2ecc71 !important;
            border-radius: 8px;
            font-size: 12px;
        }

        .alert-info {
            background: rgba(79,142,247,0.12) !important;
            border-color: rgba(79,142,247,0.3) !important;
            color: var(--blue) !important;
            border-radius: 8px;
            font-size: 12px;
        }

        .text-danger { color: #e74c3c !important; font-size: 11px; }

        /* Subtle animated bg dots */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background-image: radial-gradient(circle at 20% 50%, rgba(79,142,247,0.04) 0%, transparent 50%),
                              radial-gradient(circle at 80% 20%, rgba(79,142,247,0.04) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        .auth-container { position: relative; z-index: 1; }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="brand-logo">
            <div class="brand-icon">
                <i class="bi bi-cloud-fill"></i>
            </div>
            <h2>CloudSync</h2>
            <p>Task & Productivity Manager</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show mb-3">
                @TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
